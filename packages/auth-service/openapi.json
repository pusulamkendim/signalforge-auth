        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LoginRequest": {
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "title": "Email"
          },
          "password": {
            "type": "string",
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "title": "LoginRequest"
      },
      "MapPermissionRequest": {
        "properties": {
          "plan_type": {
            "type": "string",
            "title": "Plan Type"
          },
          "permission_name": {
            "type": "string",
            "title": "Permission Name"
          }
        },
        "type": "object",
        "required": [
