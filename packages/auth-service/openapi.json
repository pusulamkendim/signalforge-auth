        "title": "OkResponse",
        "description": "Sentinel response for boolean-outcome endpoints."
      },
      "PermissionDefinitionResponse": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "created_at"
        ],
        "title": "PermissionDefinitionResponse"
      },
      "PlanPermissionMappingResponse": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "plan_type": {
            "type": "string",
            "title": "Plan Type"
          },
          "permission_definition_id": {
            "type": "string",
            "format": "uuid",
            "title": "Permission Definition Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "plan_type",
          "permission_definition_id",
          "created_at"
        ],
        "title": "PlanPermissionMappingResponse"
