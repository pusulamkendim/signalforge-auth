                }
              }
            }
          }
        },
        "security": [
          {
            "OAuth2PasswordBearer": []
          }
        ]
      }
    },
    "/api/v1/auth/plans/map": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Map Permission To Plan",
        "description": "Attach a permission to a subscription plan. Admin only.",
        "operationId": "map_permission_to_plan_api_v1_auth_plans_map_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MapPermissionRequest"
              }
