# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/signalforge_auth

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Verification tokens
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.com
FRONTEND_URL=http://localhost:3000

# Rate limiting (slowapi format: "N/period" where period is second/minute/hour/day)
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_RESEND_VERIFICATION=3/hour
RATE_LIMIT_PASSWORD_RESET=3/hour

# App
ENVIRONMENT=development

# Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=signalforge_auth
